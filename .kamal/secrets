# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Registry password via gh CLI (uses token stored in keychain)
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# Phoenix secret key base - read from file (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=$(cat .secret_key_base)

# Database URL - Postgres running on host (not dockerized)
# host.docker.internal resolves to the Docker host from inside containers
# Database: pokevestment_prod on Mac Mini, user: holden (trust auth from Docker network)
DATABASE_URL=ecto://holden@host.docker.internal:5432/pokevestment_prod

# Pokemon TCG API key (optional but recommended for rate limits)
# Register at https://pokemontcg.io to get one
POKEMON_TCG_API_KEY=
