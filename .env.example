# Kamal registry (GitHub Container Registry)
KAMAL_REGISTRY_PASSWORD=

# Phoenix secret key base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=

# PostgreSQL connection string
# host.docker.internal resolves to the host machine from inside Docker
DATABASE_URL=ecto://USER:PASS@host.docker.internal:5432/pokevestment_prod

# Pokemon TCG API key (optional but recommended for rate limits)
POKEMON_TCG_API_KEY=
